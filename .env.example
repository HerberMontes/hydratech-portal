# ===== Conexión a Odoo =====
# NO subas el archivo .env real a GitHub. Estos valores van en
# Netlify -> Site settings -> Environment variables.
ODOO_URL=https://tuempresa.odoo.com
ODOO_DB=nombre_de_tu_base_de_datos
ODOO_USERNAME=usuario@tucorreo.com
ODOO_API_KEY=pega_aqui_tu_api_key_de_odoo

# Token simple para que el portal pueda llamar a las funciones (opcional).
# Si lo dejas vacío, las funciones no exigen token (útil solo para pruebas).
PORTAL_TOKEN=
